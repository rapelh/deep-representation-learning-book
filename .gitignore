build/
local-macros.def
*-SAVE-ERROR

# Don't want to remove all PDFs that are figures, so use targeted removal of PDFs.
!chapters/**/figs/*.pdf
!chapters/**/figs/**/*.pdf

# make4ht stale outputs in repo root
book-main*.html
book-main*.svg
book-main.css
book-main.tmp
book-main_zh*.html
book-main_zh*.svg
book-main_zh.css
book-main_zh.tmp
_build_*/
_build/
website/_build_*/

# (Temp) figures generated by make4ht in source directories 
chapters/**/*-.png

# Generated HTML/assets from build pipelines
website/html/chapters
website/html/bib.html
website/html/Ch[0-9]*.html
website/html/Chx[0-9]*.html
website/html/A[0-9]*.html
website/html/Ax[0-9]*.html
website/html/Pt[0-9]*.html
website/html/Ptx[0-9]*.html
website/html/search-index.json
website/html/book-main*.svg
website/html/book-main*.css
website/html/zh/chapters
website/html/zh/bib.html
website/html/zh/Ch[0-9]*.html
website/html/zh/A[0-9]*.html
website/html/zh/Chx[0-9]*.html
