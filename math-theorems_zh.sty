\ProvidesPackage{math-theorems_zh}
\RequirePackage{amsthm} % http://www.ams.org/arc/tex/amscls/amsthdoc.pdf
%\RequirePackage{thmtools} % https://ctan.mirrors.hoobly.com/macros/latex/contrib/thmtools/doc/thmtools-manual.pdf
\RequirePackage{tcolorbox}

%\RequirePackage[capitalize, nameinlink]{cleveref} % http://tug.ctan.org/tex-archive/macros/latex/contrib/cleveref/cleveref.pdf

\theoremstyle{plain}
\newtheorem{theorem}{定理}[chapter]
\newtheorem{corollary}{推论}[chapter]
\newtheorem{keyidea}{关键思想}[chapter]
\newtheorem{lemma}{引理}[chapter]
\newtheorem{method}{方法}[chapter]
\newtheorem{proposition}{命题}[chapter]

\theoremstyle{definition}
\newtheorem{axiom}{公理}[chapter]
\newtheorem{assumption}{假设}[chapter]
\newtheorem{definition}{定义}[chapter]
\newtheorem{model}{模型}[chapter]
\newtheorem{notation}{记号}[chapter]

\theoremstyle{remark}
\newtheorem{example}{例}[chapter]
\newtheorem{claim}{断言}[chapter]
\newtheorem{conjecture}{猜想}[chapter]
\newtheorem{exercise}{练习}[chapter]
\newtheorem{idea}{想法}[chapter]
\newtheorem{fact}{事实}[chapter]
\newtheorem{problem}{问题}[chapter]
\newtheorem{question}{问题}[chapter]
\newtheorem{remark}{注}[chapter]

\AtEndEnvironment{example}{\hfill$\blacksquare$}


%%%%% EQUATION NUMBERING
%%% TO GET EQUATION NUMBERING TO MATCH STYLE OF THEOREM
\RequirePackage{chngcntr}
\ifdef{\chapter}{
    \counterwithout{equation}{chapter}
}{
    \counterwithout{equation}{section}
}
\numberwithin{equation}{section}

%%%%% ALGORITHM NUMBERING
%%% MAKE ALGORITHM USE SAME NUMBERING AS ANYTHING ELSE
\ifdef{\chapter}{
    \counterwithin{algorithm}{chapter}
}{
    \counterwithout{algorithm}{section}
}

