% Extra TeX memory for make4ht builds (especially CJK + biblatex).
% Loaded via TEXMFCNF in build.sh — no system config changes needed.
%
% The XeTeX format bakes main_memory at build time; extra_mem_bot alone
% is ignored at runtime.  build.sh runs fmtutil-user to (re)build a
% user-level xelatex.fmt with this larger limit before calling make4ht.
main_memory = 500000000
extra_mem_bot = 990000000
